# Loaded automatically by app.py on startup (python-dotenv).

# Host/port the single Flask service binds to.
HOST=0.0.0.0
PORT=8000

# Where to read models/best_model.pkl, scaler.pkl, all_features.json,
# core_features.json, remaining_features.json from. Defaults to ./models
# next to app.py if unset -- only needed when artifacts are mounted
# elsewhere (e.g. a separate volume in production).
# ML_MODEL_DIR=models

# Where the dynamic model trained via POST /train is persisted (survives a
# restart). Defaults to ./models/dynamic if unset.
# ML_DYNAMIC_STATE_DIR=models/dynamic
